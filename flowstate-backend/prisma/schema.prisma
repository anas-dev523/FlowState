generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Frequence {
  quotidienne
  hebdomadaire
  mensuelle
}

model Utilisateur {
  id_utilisateur   Int      @id @default(autoincrement())
  prenom           String   @db.VarChar(50)
  nom              String   @db.VarChar(50)
  email            String   @unique @db.VarChar(254)
  mot_de_passe     String   @db.VarChar(255)
  date_creation    DateTime @default(now())
  date_mise_a_jour DateTime @updatedAt
  reset_token      String?   
  reset_token_expiry DateTime?

  suivis             Suivre[]
  validations        ValidationHabitude[]
  scores_journaliers ScoreJournalier[]
  sessions_focus     SessionFocus[]
  visionnages_video  VisionnageVideo[]

  @@map("utilisateurs")
}

model Habitude {
  id_habitude      Int       @id @default(autoincrement())
  titre            String    @db.VarChar(255)
  description      String?   @db.Text
  frequence        Frequence @default(quotidienne)
  est_active       Boolean   @default(true)
  date_creation    DateTime  @default(now())
  date_mise_a_jour DateTime  @updatedAt

  suivis               Suivre[]
  validations_habitude ValidationHabitude[]

  @@map("habitudes")
}

model Suivre {
  id_utilisateur Int
  id_habitude    Int

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade)
  habitude    Habitude    @relation(fields: [id_habitude], references: [id_habitude], onDelete: Cascade)

  @@id([id_utilisateur, id_habitude])
  @@map("suivre")
}

model ValidationHabitude {
  id_validation   Int      @id @default(autoincrement())
  id_utilisateur  Int
  id_habitude     Int
  date_validation DateTime @db.Date
  est_validee     Boolean  @default(false)
  note            Int?
  date_creation   DateTime @default(now())

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade)
  habitude    Habitude    @relation(fields: [id_habitude], references: [id_habitude], onDelete: Cascade)

  @@map("validations_habitude")
}

model ScoreJournalier {
  id_score       Int      @id @default(autoincrement())
  id_utilisateur Int
  date           DateTime @db.Date
  score          Int      @default(0)
  details        Json?

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade)

  @@unique([id_utilisateur, date])
  @@map("score_journalier")
}

model SessionFocus {
  id_session_focus Int       @id @default(autoincrement())
  id_utilisateur   Int
  debut            DateTime
  fin              DateTime?
  duree_reelle     Int?
  est_terminee     Boolean   @default(false)

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade)

  @@map("sessions_focus")
}

model VideoMotivation {
  id_video      Int      @id @default(autoincrement())
  titre         String   @db.VarChar(255)
  url           String   @db.VarChar(2048)
  categorie     String?  @db.VarChar(100)
  duree         Int?
  date_creation DateTime @default(now())

  visionnages VisionnageVideo[]

  @@map("videos_motivation")
}

model VisionnageVideo {
  id_visionnage   Int      @id @default(autoincrement())
  id_utilisateur  Int
  id_video        Int
  date_visionnage DateTime @default(now())
  duree_visionnee Int?

  utilisateur Utilisateur     @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade)
  video       VideoMotivation @relation(fields: [id_video], references: [id_video], onDelete: Cascade)

  @@map("visionnages_video")
}
